---
import Layout from "../../layouts/Layout.astro";
---

<Layout>
    <div class="salon-container">
        <div id="#salonWebsite" class="salon-content">
            <h1 class="salon-title">Salon Website</h1>
            <p class="salon-description">
                The website below was built for my mother's growing salon
                business. It shows clients her work as well as providing contact
                and policy information.
            </p>
            <div id="#salonWebsiteLiveDemo" class="salon-video-wrapper">
                <iframe src="https://www.maryheathermelton.com/" frameborder="0"
                ></iframe>
            </div>
            <a
                class="salon-site-link"
                href="https://www.maryheathermelton.com/"
                target="_blank"
                rel="noopener noreferrer"
            >Visit the live site &rarr;</a>
            <a class="salon-back-button" href="/proj">Back</a>
        </div>
    </div>
</Layout>

<style>
    .salon-container {
        max-width: 48rem; /* max-w-3xl */
        margin-left: auto;
        margin-right: auto;
        padding-left: 1rem; /* px-4 */
        padding-right: 1rem; /* px-4 */
        padding-top: 2rem; /* py-8 */
        padding-bottom: 2rem; /* py-8 */
    }

    .salon-content {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

    .salon-title {
        font-size: 1.5rem; /* text-2xl */
        line-height: 2rem;
        text-align: center;
        font-weight: 700; /* font-bold */
        margin: 1rem; /* m-4 */
        padding: 0.5rem; /* p-2 */
    }

    .salon-description {
        max-width: 36rem; /* max-w-xl */
        text-align: center;
        padding: 0.5rem; /* p-2 */
        margin: 0.5rem; /* m-2 */
    }

    .salon-video-wrapper {
        width: 100%;
        aspect-ratio: 16 / 9;
        margin-top: 1rem;
        margin-bottom: 0.5rem;
        border-radius: 0.5rem;
        overflow: hidden;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.18);
    }

    .salon-video-wrapper iframe {
        width: 100%;
        height: 100%;
        display: block;
    }

    .salon-site-link {
        font-size: 0.9rem;
        color: #3b82f6;
        text-decoration: none;
        margin-bottom: 0.5rem;
    }

    .salon-site-link:hover {
        text-decoration: underline;
    }

    @media (prefers-color-scheme: dark) {
        .salon-site-link {
            color: #93c5fd;
        }

        .salon-video-wrapper {
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.45);
        }
    }

    .salon-back-button {
        display: inline-block;
        background-color: #3b82f6; /* bg-blue-500 */
        color: #ffffff; /* text-white */
        font-weight: 700; /* font-bold */
        padding-top: 0.5rem; /* py-2 */
        padding-bottom: 0.5rem; /* py-2 */
        padding-left: 1rem; /* px-4 */
        padding-right: 1rem; /* px-4 */
        border-radius: 0.25rem; /* rounded */
        transition: all 0.3s ease-in-out; /* transition duration-300 ease-in-out */
        margin-top: 2rem; /* mt-8 */
        margin-bottom: 1rem; /* mb-4 */
        text-decoration: none;
    }

    .salon-back-button:hover {
        background-color: #1d4ed8; /* hover:bg-blue-700 */
    }
</style>
