---
import Navbar from "./ui/Navbar.astro";
import Layout from "../layouts/Layout.astro";
import Footer from "./ui/Footer.astro";
---

<Layout>
    <div class="container">
        <Navbar />
        <main id="hero">
            <div id="hero-left">
                <p id="hero-bio">
                    I work on things that people and myself find useful and
                    enjoy keeping solutions simple and open.
                </p>
            </div>
            <div id="hero-cards">
                <div class="card" id="card-role">
                    <span class="card-label">Role</span>
                    <span class="card-value">SWE · DevOps · IoT</span>
                </div>
                <div class="card" id="card-stack">
                    <span class="card-label">Stack</span>
                    <span class="card-value"
                        >Go · JavaScript · Linux · Docker</span
                    >
                </div>
                <div class="card" id="card-host">
                    <span class="card-label">Interests</span>
                    <span class="card-value"
                        >Open Source · High Availability Systems</span
                    >
                </div>
            </div>
        </main>
        <Footer />
    </div>
</Layout>

<style>
    .container {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }
    #hero {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        gap: 3rem;
        padding: 4rem 1.75rem;
        flex: 1;
    }
    #hero-left {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        max-width: 420px;
    }
    #hero-bio {
        margin: 0.5rem 0 0;
        line-height: 1.6;
        opacity: 0.85;
        font-size: x-large;
    }
    #hero-cards {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    .card {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        padding: 1rem 1.4rem;
        border-radius: 0.75rem;
        background-color: var(--button-group-background-color-light);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        min-width: 220px;
        transition: var(--button-animation-transition);
    }
    .card:hover {
        transform: translateY(-3px) rotate(1deg);
        box-shadow: 0 8px 28px rgba(0, 0, 0, 0.13);
    }
    #card-role {
        align-self: flex-end;
    }
    #card-stack {
        align-self: flex-end;
    }
    #card-host {
        align-self: flex-end;
    }
    .card-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        opacity: 0.5;
    }
    .card-value {
        font-size: 1rem;
        font-weight: bold;
    }
    @media (prefers-color-scheme: dark) {
        .card {
            background-color: var(--button-group-background-color-dark);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
        }
        .card:hover {
            box-shadow: 0 8px 28px rgba(0, 0, 0, 0.5);
        }
    }
    @media (max-width: 650px) {
        #hero {
            flex-direction: column;
            padding: 2.5rem 1.25rem;
        }
        #card-role,
        #card-stack,
        #card-host {
            transform: none;
            align-self: auto;
        }
    }
</style>
