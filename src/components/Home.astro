---
import Navbar from "./ui/Navbar.astro";
import Layout from "../layouts/Layout.astro";
import Projects from "./Projects.astro";
import Contact from "./Contact.astro";
import Footer from "./ui/Footer.astro";
---

<script>
    // 604800 = 1 week
    const COOKIE_ATTRS = "; SameSite=Strict; Secure; Max-Age=604800";
    // hrc = home render count
    let hrc = document.cookie.match(/(?:^|;\s*)hrc=(\d+)/)?.[1];
    const id = document.getElementById("about-sub");
    let current_count: number;
    const incr = () =>
        (document.cookie = `hrc=${++current_count}${COOKIE_ATTRS}`);
    if (!hrc) {
        document.cookie = `hrc=0${COOKIE_ATTRS}`;
        hrc = "0";
    }
    if (hrc) current_count = Number.parseInt(hrc);
    else throw new Error("Failed to find cookie");
    if (current_count === 0) {
        // Cute load in sleep
        await new Promise((res) => setTimeout(res, 500));
        const acronyms = [
            "Engineer",
            "Developer",
            "Enjoyer",
            "Destroyer",
            "Person",
        ];

        const etc = [
            "Hardware Recycling",
            "Network Management",
            "Embedded Systems",
            "3D Printing",
            "Homelab Enthusiast",
        ];

        for (let index in acronyms) {
            if (id)
                id.innerText = `Software ${acronyms[index]} - ${etc[index]}`;
            await new Promise((res) => setTimeout(res, 1000));
        }
        incr();
    } else {
        const friend = current_count > 5;
        if (id)
            id.innerText = friend
                ? "Hey Friend! - See Projects ↓"
                : "Software Person - Homelab Enthusiast";
        incr();
    }
</script>

<Layout>
    <div class="container">
        <Navbar />
        <main id="content">
            <a href="/about" id="about-card">
                <div id="about-card-inner">
                    <div id="about-text">
                        <span id="about-label">About</span>
                        <span id="about-sub"> </span>
                    </div>
                    <span id="about-arrow">→</span>
                </div>
            </a>
            <div id="grid">
                <Projects />
                <Contact />
            </div>
        </main>
        <Footer />
    </div>
</Layout>

<style>
    .container {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }
    #content {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        padding: 2rem 1.75rem;
        flex: 1;
    }
    #about-card {
        display: block;
        text-decoration: none;
        color: inherit;
        background-color: var(--button-group-background-color-light);
        border-radius: 1rem;
        padding: 1.5rem 2rem;
        transition: var(--button-animation-transition);
    }
    #about-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    }
    #about-card-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    #about-text {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }
    #about-label {
        font-size: 1.4rem;
        font-weight: bold;
    }
    #about-sub {
        font-size: 0.95rem;
        opacity: 0.7;
    }
    #about-arrow {
        font-size: 1.5rem;
        transition: var(--button-animation-transition);
    }
    #about-card:hover #about-arrow {
        transform: translateX(4px);
    }
    #grid {
        display: flex;
        flex-direction: row;
        gap: 2rem;
        align-items: flex-start;
        flex-wrap: wrap;
    }
    #grid > :global(*) {
        flex: 1;
        min-width: 200px;
    }
    @media (prefers-color-scheme: dark) {
        #about-card {
            background-color: var(--button-group-background-color-dark);
        }
        #about-card:hover {
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
        }
    }
    @media (max-width: 600px) {
        #grid {
            flex-direction: column;
        }
    }
</style>
