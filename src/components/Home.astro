---
import Navbar from "./ui/Navbar.astro";
import Layout from "../layouts/Layout.astro";
import Projects from "./Projects.astro";
import Contact from "./Contact.astro";
import Footer from "./ui/Footer.astro";
---

<Layout>
    <div class="container">
        <Navbar />
        <main id="content">
            <a href="/about" id="about-card">
                <div id="about-card-inner">
                    <div id="about-text">
                        <span id="about-label">About</span>
                        <span id="about-sub">Software Developer · Homelab Enthusiast</span>
                    </div>
                    <span id="about-arrow">→</span>
                </div>
            </a>
            <div id="grid">
                <Projects />
                <Contact />
            </div>
        </main>
        <Footer />
    </div>
</Layout>

<style>
    .container {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }
    #content {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        padding: 2rem 1.75rem;
        flex: 1;
    }
    #about-card {
        display: block;
        text-decoration: none;
        color: inherit;
        background-color: var(--button-group-background-color-light);
        border-radius: 1rem;
        padding: 1.5rem 2rem;
        transition: var(--button-animation-transition);
    }
    #about-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    }
    #about-card-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    #about-text {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }
    #about-label {
        font-size: 1.4rem;
        font-weight: bold;
    }
    #about-sub {
        font-size: 0.95rem;
        opacity: 0.7;
    }
    #about-arrow {
        font-size: 1.5rem;
        transition: var(--button-animation-transition);
    }
    #about-card:hover #about-arrow {
        transform: translateX(4px);
    }
    #grid {
        display: flex;
        flex-direction: row;
        gap: 2rem;
        align-items: flex-start;
        flex-wrap: wrap;
    }
    #grid > :global(*) {
        flex: 1;
        min-width: 200px;
    }
    @media (prefers-color-scheme: dark) {
        #about-card {
            background-color: var(--button-group-background-color-dark);
        }
        #about-card:hover {
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
        }
    }
    @media (max-width: 600px) {
        #grid {
            flex-direction: column;
        }
    }
</style>
