---

<nav id="nav">
    <a href="/" id="site-name">Tommy Hall</a>
</nav>

<script is:inline>
    if (window.location.pathname != "/") {
        const el = document.getElementById("site-name");
        const original = el.innerText;
        const target = "Back";
        let i = original.length;

        const del = setInterval(() => {
            el.innerText = original.slice(0, i--);

            if (i < 0) {
                clearInterval(del);
                let j = 0;
                const type = setInterval(() => {
                    el.innerText = target.slice(0, ++j);
                    if (j >= target.length) clearInterval(type);
                }, 80);
            }
        }, 50);
    }
</script>

<style>
    #nav {
        display: flex;
        align-items: center;
        padding: 1.25rem 1.75rem;
        border-bottom: 1px solid rgba(128, 128, 128, 0.15);
    }
    #site-name {
        font-size: 1.5rem;
        font-weight: bold;
        text-decoration: none;
        color: #292524;
        letter-spacing: 0.02em;
        transition: var(--button-animation-transition);
    }
    #site-name:hover {
        opacity: 0.6;
    }
    @media (prefers-color-scheme: dark) {
        #site-name {
            color: white;
        }
    }
</style>
