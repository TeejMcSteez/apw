---
const base = "https://teejmcsteez.tech";
const pages = [
    { url: "/", priority: "1.0" },
    { url: "/about", priority: "0.8" },
    { url: "/projects/ha", priority: "0.6" },
    { url: "/projects/homelab", priority: "0.6" },
    { url: "/projects/monitor", priority: "0.6" },
    { url: "/projects/salon", priority: "0.6" },
];
---

<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
    {pages.map(({ url, priority }) => (
        <url>
            <loc>{base}{url}</loc>
            <priority>{priority}</priority>
        </url>
    ))}
</urlset>
